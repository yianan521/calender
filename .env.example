# === AI Voice Scheduler — Environment Configuration ===

# LLM API (OpenAI-compatible)
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=your-openai-api-key-here
LLM_MODEL=gpt-4o

# Map API (Amap / 高德地图)
MAP_API_KEY=your-amap-api-key-here
MAP_CITY=北京

# Database
DATABASE_URL=sqlite:///./scheduler.db

# Working hours for daily brief & scheduling (defaults 8-22)
WORKING_HOUR_START=8
WORKING_HOUR_END=22

# Debug mode
DEBUG=false
